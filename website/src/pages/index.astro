---
import '../styles/theme.css';

const title = 'Scripting Nodes';
const tagline = 'Build Blender add-ons visually with nodes.';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {tagline}</title>
    <meta name="description" content={tagline} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>{tagline}</p>
      <nav>
        <a class="primary" href="/store">Browse the store</a>
        <a href="/docs/">Read the docs</a>
        <a href="https://github.com/joshuaknauber/scripting_nodes">GitHub</a>
      </nav>
    </main>

    <style>
      main {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
        text-align: center;
        gap: 1rem;
      }
      h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        letter-spacing: -0.02em;
      }
      p {
        font-size: 1.25rem;
        color: var(--muted);
        margin: 0;
        max-width: 32rem;
      }
      nav {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      nav a {
        padding: 0.625rem 1.25rem;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        transition:
          background 0.15s,
          border-color 0.15s,
          color 0.15s;
      }
      nav a:hover {
        border-color: var(--fg);
      }
      nav a.primary {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--accent-fg);
        font-weight: 500;
      }
      nav a.primary:hover {
        background: #ffffff;
        border-color: #ffffff;
      }
    </style>
  </body>
</html>
